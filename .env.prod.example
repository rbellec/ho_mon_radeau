# Production environment variables
# Copy to .env.prod and fill in real values

# Database (container-internal, credentials for the postgres container)
POSTGRES_USER=ho_mon_radeau
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=ho_mon_radeau_prod

# Phoenix
SECRET_KEY_BASE=changeme_generate_with_mix_phx_gen_secret
PHX_HOST=hmr.bellec.in

# Port exposed on the host (Traefik proxies to this)
EXPOSED_PORT=8081

# Email (Resend)
RESEND_API_KEY=re_xxx
MAILER_FROM_EMAIL=noreply@homonradeau.fr

# S3 storage (optional, uncomment if needed)
# BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL_S3=
# AWS_REGION=auto
