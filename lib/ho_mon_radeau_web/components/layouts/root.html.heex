<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Ho Mon Radeau" suffix=" · Tutto Blu">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body class="bg-base-100 antialiased">
    <header class="navbar bg-base-100 border-b border-base-200 px-4 sm:px-6 lg:px-8 sticky top-0 z-50">
      <div class="flex-1 gap-2">
        <a href="/" class="flex items-center gap-2 text-primary font-bold text-xl">
          <span class="text-2xl">🚣</span>
          <span class="hidden sm:inline">Ho Mon Radeau</span>
        </a>

        <%!-- Main navigation for authenticated users --%>
        <%= if @current_scope do %>
          <nav class="hidden md:flex ml-6">
            <ul class="menu menu-horizontal px-1 space-x-1 text-sm">
              <li><.link navigate={~p"/"} class="font-medium">Accueil</.link></li>
              <li><.link navigate={~p"/radeaux"}>Les radeaux</.link></li>
              <li><.link navigate={~p"/mon-radeau"}>Mon radeau</.link></li>
            </ul>
          </nav>
        <% end %>
      </div>
      <div class="flex-none">
        <ul class="menu menu-horizontal px-1 space-x-1 items-center text-sm">
          <%= if @current_scope do %>
            <%!-- Admin dropdown --%>
            <%= if @current_scope.user.is_admin do %>
              <li>
                <details class="dropdown dropdown-end">
                  <summary class="font-medium text-secondary">Admin</summary>
                  <ul class="dropdown-content menu bg-base-200 rounded-box z-[1] w-52 p-2 shadow-lg mt-2">
                    <li><.link href={~p"/admin/utilisateurs"}>Utilisateurs</.link></li>
                    <li><.link href={~p"/admin/fiches"}>Fiches d'inscription</.link></li>
                    <li><.link href={~p"/admin/radeaux"}>Radeaux</.link></li>
                    <li>
                      <.link href={~p"/admin/equipes-transverses"}>Équipes transverses</.link>
                    </li>
                    <li><.link href={~p"/admin/bidons"}>Bidons</.link></li>
                    <li><.link href={~p"/admin/cuf"}>CUF</.link></li>
                    <li><.link href={~p"/admin/departs"}>Départs</.link></li>
                    <li class="divider"></li>
                    <li><.link href={~p"/kaffy"}>Kaffy Admin</.link></li>
                  </ul>
                </details>
              </li>
            <% end %>

            <%!-- User menu --%>
            <li>
              <details class="dropdown dropdown-end">
                <summary class="font-medium">
                  {@current_scope.user.nickname || @current_scope.user.email}
                </summary>
                <ul class="dropdown-content menu bg-base-200 rounded-box z-[1] w-52 p-2 shadow-lg mt-2">
                  <li><.link navigate={~p"/mon-profil"}>Mon profil</.link></li>
                  <li class="md:hidden"><.link navigate={~p"/"}>Accueil</.link></li>
                  <li class="md:hidden"><.link navigate={~p"/radeaux"}>Les radeaux</.link></li>
                  <li class="md:hidden"><.link navigate={~p"/mon-radeau"}>Mon radeau</.link></li>
                  <li class="divider"></li>
                  <li><.link href={~p"/users/log-out"} method="delete">Déconnexion</.link></li>
                </ul>
              </details>
            </li>
          <% else %>
            <li>
              <a href="https://tuttoblu.framer.website/" target="_blank" class="hidden sm:flex">
                Tutto Blu
              </a>
            </li>
            <li>
              <.link href={~p"/users/register"} class="btn btn-ghost btn-sm">Inscription</.link>
            </li>
            <li>
              <.link href={~p"/users/log-in"} class="btn btn-primary btn-sm">Connexion</.link>
            </li>
          <% end %>
        </ul>
      </div>
    </header>
    {@inner_content}
  </body>
</html>
